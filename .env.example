# =============================================================================
# Trip Planner Configuration (.env.example)
# =============================================================================
# Copy this file to .env and fill in your credentials.
# Never commit the actual .env file to version control.
#
# Usage:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Provider Mode
# ---------------------------------------------------------------------------
# Options: "local" (demo/fallback) | "amap" (production with Amap services)
# In "local" mode, all external services are bypassed; demo data is used.
# In "amap" mode, Amap REST API or MCP endpoint is required.
TRIP_PROVIDER_MODE="local"

# ---------------------------------------------------------------------------
# SSL / Certificate
# ---------------------------------------------------------------------------
# Set to "false" to skip SSL verification (local dev only).
# Use TRIP_SSL_CA_FILE to point to a custom CA bundle behind corporate proxy.
TRIP_SSL_VERIFY="true"
# TRIP_SSL_CA_FILE="C:\path\to\company-ca.pem"

# ---------------------------------------------------------------------------
# AMAP (Gaode) WebService API - Direct Connection
# ---------------------------------------------------------------------------
# Needed when TRIP_PROVIDER_MODE="amap" and using REST API directly.
# TRIP_AMAP_API_KEY="your-amap-api-key"

# ---------------------------------------------------------------------------
# AMAP MCP (Model Context Protocol) - Alternative to REST API
# ---------------------------------------------------------------------------
# Set TRIP_MCP_HTTP_URL when you have an external MCP endpoint serving Amap data.
# Or set TRIP_MCP_ALLOW_INPROCESS="true" to use the project's built-in MCP server.
#
# Note: MCP mode and REST direct mode are mutually exclusive. MCP takes priority.
# TRIP_MCP_HTTP_URL="http://127.0.0.1:8765/mcp"
# TRIP_MCP_ALLOW_INPROCESS="false"
TRIP_MCP_TIMEOUT_SECONDS="20"

# Optional: Custom MCP tool name mapping (if your MCP server uses different names)
# TRIP_AMAP_MCP_POI_TOOL="amap_poi_search"
# TRIP_AMAP_MCP_HOTEL_TOOL="amap_hotel_anchor"
# TRIP_AMAP_MCP_WEATHER_TOOL="amap_weather_constraints"
# TRIP_AMAP_MCP_MATRIX_TOOL="amap_distance_matrix"

# ---------------------------------------------------------------------------
# LLM (Large Language Model) for Intent Parsing & Itinerary Narration
# ---------------------------------------------------------------------------
# When enabled, LLM handles natural language intent parsing and route narration.
# When disabled or unavailable, rule-based parsing and template narration are used.
TRIP_LLM_ENABLED="false"
# TRIP_LLM_API_KEY="your-llm-api-key"
# TRIP_LLM_BASE_URL="https://api.openai.com/v1"
# TRIP_LLM_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Job Store Persistence
# ---------------------------------------------------------------------------
# Path for job store JSONL file (relative to backend/ or absolute).
# If the path is not writable, jobs will remain in memory only.
# TRIP_JOB_STORE_PATH="data/jobs.jsonl"
# "database" is the production default. Use "jsonl" only for local fallback
# or isolated algorithm tests.
# TRIP_PERSISTENCE_BACKEND="database"

# ---------------------------------------------------------------------------
# PostgreSQL Persistence
# ---------------------------------------------------------------------------
# Required when database-backed job and itinerary persistence is enabled.
# DATABASE_URL="postgresql+psycopg2://trip_planner:change-me@127.0.0.1:5432/trip_planner"
# TRIP_DB_POOL_SIZE="5"
# TRIP_DB_MAX_OVERFLOW="10"
# TRIP_DB_POOL_TIMEOUT_SECONDS="30"
# TRIP_DB_CONNECT_TIMEOUT_SECONDS="5"

# ---------------------------------------------------------------------------
# Frontend AMAP JS API Key (for browser-side map rendering)
# ---------------------------------------------------------------------------
# VITE_AMAP_JS_KEY="your-amap-js-api-key"
# VITE_AMAP_SECURITY_CODE="your-amap-security-code"

# ---------------------------------------------------------------------------
# CORS (allowed origins for browser requests)
# ---------------------------------------------------------------------------
# TRIP_CORS_ORIGINS="http://localhost:5173,http://localhost:4173"

# ---------------------------------------------------------------------------
# Solver Parameters
# ---------------------------------------------------------------------------
# TRIP_SOLVER_TIMEOUT_MS=1200
# TRIP_MAX_DAY_MINUTES=600
# TRIP_CITY_DETOUR_FACTOR=1.4
# TRIP_MATRIX_CACHE_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Unsplash (for background images, optional)
# ---------------------------------------------------------------------------
# UNSPLASH_ACCESS_KEY="your-unsplash-access-key"
